<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>rest</title>
    <link rel="stylesheet" href="/style.css"/>
</head>
<body>
    <h1>
        user and content
        <%for(post of posts){%>
            <h2 class="user">
                <%=post.username%>
            </h2>
            <h3 class="cont">
                <%=post.content%>
            </h3>
            <%}%>
    </h1>
    
</body>
</html>